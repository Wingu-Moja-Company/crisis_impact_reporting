                "description": "Azure region for all resources"
              }
            },
            "sku": {
              "type": "string",
              "defaultValue": "Standard_GRS",
              "allowedValues": [
                "Standard_LRS",
                "Standard_GRS"
              ],
              "metadata": {
                "description": "Storage redundancy — LRS for dev, GRS for production"
              }
            }
          },
          "variables": {
            "storageAccountName": "[format('stcrisis{0}', uniqueString(resourceGroup().id))]"
          },
