COSMOS_DATABASE=crisis-platform

# Storage
STORAGE_ACCOUNT_NAME=
STORAGE_CONNECTION_STRING=

# PostgreSQL / PostGIS
POSTGRES_HOST=
POSTGRES_DB=crisis_footprints
POSTGRES_USER=
POSTGRES_PASSWORD=

# Azure AI Services
AI_VISION_ENDPOINT=https://<account>.cognitiveservices.azure.com
