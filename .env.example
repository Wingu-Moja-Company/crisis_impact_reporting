# Africa's Talking (SMS fallback)
AT_API_KEY=
AT_USERNAME=

# what3words
W3W_API_KEY=

# Application
ENVIRONMENT=development
CRISIS_EVENT_ID=ke-flood-dev
LOG_LEVEL=INFO
MAX_REPORTS_PER_USER_PER_HOUR=20
DUPLICATE_WINDOW_SECONDS=60
