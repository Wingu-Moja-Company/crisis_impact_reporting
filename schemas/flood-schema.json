      "options": [
        { "value": "food_water",    "label": { "en": "Food and water",       "ar": "الغذاء والماء",    "fr": "Nourriture et eau",    "zh": "食物和水",    "ru": "Еда и вода",       "es": "Comida y agua" } },
        { "value": "shelter",       "label": { "en": "Shelter",              "ar": "مأوى",             "fr": "Abri",                 "zh": "庇护所",      "ru": "Жильё",            "es": "Refugio" } },
        { "value": "medical",       "label": { "en": "Medical assistance",   "ar": "مساعدة طبية",     "fr": "Aide médicale",        "zh": "医疗援助",    "ru": "Медицинская помощь","es": "Asistencia médica" } },
        { "value": "evacuation",    "label": { "en": "Evacuation",           "ar": "إخلاء",            "fr": "Évacuation",           "zh": "撤离",        "ru": "Эвакуация",        "es": "Evacuación" } },
        { "value": "search_rescue", "label": { "en": "Search and rescue",    "ar": "بحث وإنقاذ",      "fr": "Recherche et secours",  "zh": "搜救",        "ru": "Поиск и спасение", "es": "Búsqueda y rescate" } }
      ]
