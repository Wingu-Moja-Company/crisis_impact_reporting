      "options": [
        { "value": "ankle",  "label": { "en": "Ankle deep (< 0.5 m)", "ar": "< 0.5 م", "fr": "< 0,5 m", "zh": "< 0.5 米", "ru": "< 0,5 м", "es": "< 0,5 m" } },
        { "value": "knee",   "label": { "en": "Knee deep (0.5–1 m)",  "ar": "0.5–1 م", "fr": "0,5–1 m",  "zh": "0.5–1 米", "ru": "0,5–1 м",  "es": "0,5–1 m" } },
