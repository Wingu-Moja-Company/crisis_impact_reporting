        { "value": "no_damage",  "label": { "en": "No damage observed",    "ar": "لا يوجد ضرر",   "fr": "Aucun dommage",         "zh": "无损坏",       "ru": "Повреждений нет",     "es": "Sin daños" } },
        { "value": "minor",      "label": { "en": "Minor damage",           "ar": "ضرر طفيف",      "fr": "Dommages mineurs",       "zh": "轻微损坏",     "ru": "Незначительный ущерб","es": "Daño menor" } },
        { "value": "moderate",   "label": { "en": "Moderate damage",        "ar": "ضرر معتدل",     "fr": "Dommages modérés",       "zh": "中等损坏",     "ru": "Умеренный ущерб",    "es": "Daño moderado" } },
        { "value": "severe",     "label": { "en": "Severe damage",          "ar": "ضرر شديد",      "fr": "Dommages graves",        "zh": "严重损坏",     "ru": "Серьёзный ущерб",    "es": "Daño grave" } },
